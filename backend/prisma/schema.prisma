generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum MemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Company {
  id             Int      @id @default(autoincrement())
  name           String
  slug           String   @unique
  logoUrl        String?
  primaryColor   String   @default("#100F31")
  secondaryColor String   @default("#12375F")
  accentColor    String   @default("#EE3B1B")
  bgColor        String   @default("#f8fafc")
  textColor      String   @default("#1e293b")
  domain         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  users          User[]
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             Int        @id @default(autoincrement())
  fullName       String
  email          String     @unique
  password       String?
  role           UserRole   @default(EMPLOYEE)
  documentNumber String?
  position       String?
  isActive       Boolean    @default(true)
  departmentId   Int?
  roleId         Int?
  activeAgentId  Int?
  companyId      Int?
  department     Department? @relation(fields: [departmentId], references: [id])
  roleRelation   Role?       @relation(fields: [roleId], references: [id])
  activeAgent    Agent?      @relation("UserActiveAgent", fields: [activeAgentId], references: [id])
  company        Company?    @relation(fields: [companyId], references: [id])
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  createdProjects    Project[]
  projectMemberships ProjectMember[]
  taskAssignees      TaskAssignee[]
  toolAssignments    ToolAssignment[]
  toolAudits         ToolAuditLog[]
  agentLinks         UserAgent[]
  conversations      Conversation[]
  aiLogs             AiLog[]
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdById Int
  createdBy   User   @relation(fields: [createdById], references: [id])

  members ProjectMember[]
  tasks   Task[]
}

model ProjectMember {
  id     Int        @id @default(autoincrement())
  role   MemberRole @default(MEMBER)

  projectId Int
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    Int
  user      User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Task {
  id             Int        @id @default(autoincrement())
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime?
  endDate        DateTime?
  estimatedHours Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  projectId      Int
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignees      TaskAssignee[]
}

model TaskAssignee {
  id       Int  @id @default(autoincrement())
  taskId   Int
  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId   Int
  user     User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}

model Agent {
  id             Int      @id @default(autoincrement())
  name           String
  instructions   String
  scope          String   @default("GLOBAL")
  isActive       Boolean  @default(true)
  createdBy      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  activeUsers    User[]   @relation("UserActiveAgent")
  userLinks      UserAgent[]
  conversations  Conversation[]
  @@unique([createdBy, name])
}

model UserAgent {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   Int
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@unique([userId, agentId])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  agentId   Int
  agent     Agent    @relation(fields: [agentId], references: [id])
  context   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
  @@index([userId])
  @@index([agentId])
}

model ChatMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  tokensUsed     Int?
  model          String?
  createdAt      DateTime     @default(now())
  @@index([conversationId])
}

model AiLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  action       String
  model        String
  tokensUsed   Int?
  success      Boolean
  errorMessage String?
  metadata     Json?
  createdAt    DateTime @default(now())
  @@index([userId])
  @@index([createdAt])
}

model Tool {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assignments ToolAssignment[]
}

model ToolAssignment {
  id        Int      @id @default(autoincrement())
  toolId    Int
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  version   String?
  licenseKey String?
  assignedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@unique([toolId, userId])
  audits ToolAuditLog[]
}

model ToolAuditLog {
  id           Int      @id @default(autoincrement())
  assignmentId Int
  assignment   ToolAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  action       String
  performedBy  Int
  performer    User     @relation(fields: [performedBy], references: [id])
  details      String?
  createdAt    DateTime @default(now())
  @@index([assignmentId])
  @@index([createdAt])
}

// ─── CACAO MODULE ───────────────────────────────────────────

model CacaoSupplier {
  id           Int      @id @default(autoincrement())
  name         String
  contact      String?
  phone        String?
  paymentTerms String?
  bank         String?
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  receptions   CacaoReception[]
  settlements  CacaoSettlement[]
  payables     CacaoPayable[]
}

model CacaoClient {
  id        Int      @id @default(autoincrement())
  name      String
  country   String?
  contact   String?
  email     String?
  phone     String?
  companyId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shipments    CacaoShipment[]
  receivables  CacaoReceivable[]
}

model CacaoQuality {
  id                Int      @id @default(autoincrement())
  name              String   @unique
  humidityDiscount  Float    @default(7)
  impurityDiscount  Float    @default(1)
  isFixedPrice      Boolean  @default(false)
  fixedPrice        Float?
  lots              CacaoLot[]
}

model CacaoLot {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  qualityId    Int
  quality      CacaoQuality @relation(fields: [qualityId], references: [id])
  netWeight    Float
  averageCost  Float    @default(0)
  differential Float?   // Diferencial pactado ($/T) - viaja dormido hasta fijacion
  status       String   @default("OPEN")
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  receptions   CacaoReception[]
  kardex       CacaoKardex[]
  settlements  CacaoSettlementLot[]
  shipments    CacaoShipmentLot[]
  priceFixings CacaoPriceFixing[]
}

model CacaoReception {
  id               Int      @id @default(autoincrement())
  date             DateTime
  supplierId       Int
  supplier         CacaoSupplier @relation(fields: [supplierId], references: [id])
  guideNumber      String
  unitOfMeasure    String   @default("KG") // TON, KG, SACO
  grossWeight      Float
  tare             Float    @default(0)
  netWeight        Float
  humidity         Float    @default(0)
  impurities       Float    @default(0)
  provisionalPrice Float    @default(0)
  differential     Float?   // Diferencial pactado ($/T) - viaja dormido hasta fijacion
  qualityId        Int?
  lotId            Int?
  lot              CacaoLot? @relation(fields: [lotId], references: [id])
  companyId        Int
  createdBy        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CacaoSettlement {
  id              Int      @id @default(autoincrement())
  date            DateTime
  supplierId      Int
  supplier        CacaoSupplier @relation(fields: [supplierId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  totalNetWeight  Float    @default(0)
  totalDeductions Float    @default(0)
  finalPrice      Float    @default(0)
  totalAmount     Float    @default(0)
  status          String   @default("PENDING")
  companyId       Int
  createdBy       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lots            CacaoSettlementLot[]
  payable         CacaoPayable?
}

model CacaoSettlementLot {
  id           Int      @id @default(autoincrement())
  settlementId Int
  settlement   CacaoSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  lotId        Int
  lot          CacaoLot @relation(fields: [lotId], references: [id])
  quantity     Float
  unitCost     Float
  createdAt    DateTime @default(now())
}

model CacaoKardex {
  id            Int      @id @default(autoincrement())
  lotId         Int
  lot           CacaoLot @relation(fields: [lotId], references: [id])
  type          String
  quantity      Float
  unitCost      Float
  totalCost     Float
  balanceQty    Float
  balanceCost   Float
  date          DateTime
  reference     String?
  referenceUnit String?
  companyId     Int
  createdAt     DateTime @default(now())
}

model CacaoPriceFixing {
  id             Int      @id @default(autoincrement())
  lotId          Int
  lot            CacaoLot @relation(fields: [lotId], references: [id])
  referencePrice Float?
  differential   Float?
  fixedPrice     Float?
  pendingWeight  Float?
  fixedDate      DateTime?
  deadline       DateTime?
  status         String   @default("OPEN")
  companyId      Int
  createdBy      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CacaoShipment {
  id             Int      @id @default(autoincrement())
  date           DateTime
  clientId       Int
  client         CacaoClient @relation(fields: [clientId], references: [id])
  contractRef    String
  unitOfMeasure  String   @default("KG") // TON, KG, SACO
  totalWeight    Float
  totalWeightKg  Float    // Peso total siempre en kg para kárdex
  totalCost      Float
  salePrice      Float
  salePricePerKg Float    // Precio de venta siempre en $/kg para kárdex
  margin         Float    @default(0)
  status         String   @default("PENDING")
  companyId      Int
  createdBy      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lots           CacaoShipmentLot[]
  receivable     CacaoReceivable?
}

model CacaoShipmentLot {
  id              Int      @id @default(autoincrement())
  shipmentId      Int
  shipment        CacaoShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  lotId           Int
  lot             CacaoLot @relation(fields: [lotId], references: [id])
  quantity        Float    // Cantidad en la unidad original del usuario
  quantityKg      Float    // Cantidad convertida a kg para kárdex
  unitCost        Float
  saleAmount      Float
  unitOfMeasure   String   @default("KG")
  createdAt       DateTime @default(now())
}

model CacaoPayable {
  id           Int      @id @default(autoincrement())
  settlementId Int      @unique
  settlement   CacaoSettlement @relation(fields: [settlementId], references: [id])
  supplierId   Int
  supplier     CacaoSupplier @relation(fields: [supplierId], references: [id])
  totalAmount  Float
  paidAmount   Float    @default(0)
  dueDate      DateTime
  status       String   @default("PENDING")
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  payments     CacaoPayment[]
}

model CacaoReceivable {
  id             Int      @id @default(autoincrement())
  shipmentId     Int      @unique
  shipment       CacaoShipment @relation(fields: [shipmentId], references: [id])
  clientId       Int
  client         CacaoClient @relation(fields: [clientId], references: [id])
  totalAmount    Float
  receivedAmount Float    @default(0)
  dueDate        DateTime
  status         String   @default("PENDING")
  companyId      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  payments       CacaoPayment[]
}

model CacaoPayment {
  id           Int      @id @default(autoincrement())
  type         String
  amount       Float
  method       String   @default("TRANSFER")
  reference    String?
  companyId    Int
  createdAt    DateTime @default(now())
  payableId    Int?
  payable      CacaoPayable? @relation(fields: [payableId], references: [id])
  receivableId Int?
  receivable   CacaoReceivable? @relation(fields: [receivableId], references: [id])
}

model CacaoUnitConfig {
  id           Int      @id @default(autoincrement())
  name         String   // SACO_MICHOACAN, SACO_ESTANDAR, SACO_PERSONALIZADO
  displayName  String   // "Saco Michoacán (90 kg)"
  kgPerUnit    Float    // Cuántos kg equivalen 1 unidad de esta medida
  isDefault    Boolean  @default(false)
  companyId    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
